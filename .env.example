# HealthInsuranceRenew — Environment Variables
# Copy to .env.local and fill in values

# Public site URL (used for canonical URLs, OG tags, sitemaps)
NEXT_PUBLIC_SITE_URL=https://healthinsurancerenew.com

# Data directory — local path to processed JSON datasets
# Local dev: ./data/processed (default, relative to project root)
# Vercel: auto-resolved via build step
DATA_DIR=./data/processed

# Vercel Blob Storage — for large files (formulary 7.2GB, sbc 429MB, plan_intelligence 107MB)
# Get token from: Vercel Dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=

# Optional: Google Maps for service area embeds (future)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Analytics
# NEXT_PUBLIC_GTM_ID=
